# One-click server go-live bundle template
# Usage:
# 1) cp deploy/env/go_live_bundle.example.env deploy/env/go_live_bundle.env
# 2) fill required values
# 3) ./deploy/run_server_go_live_bundle.sh deploy/env/go_live_bundle.env

# Required for provider recovery + smoke
DIFY_TENANT_ID=7980ac46-b7f0-4f67-b94e-fbcc0bf48a46
DIFY_APP_TOKEN=app-xxxxxxxxxxxxxxxxxxxxxxxx
DIFY_ENDPOINT_URL=http://ai.little100.cn:3000/v1
OPENAI_COMPAT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Required for stability stage (no skip-failover-eval)
DIFY_WORKFLOW_ID=d3e2be2d-c487-4dea-b9ed-8e374ba7ea07

# Optional model / endpoint
DIFY_API_BASE=http://127.0.0.1:8080
DIFY_PROVIDER_NAME=langgenius/openai_api_compatible/openai_api_compatible
DIFY_MODEL_NAME=gpt-5.2-codex
DIFY_MODEL_TYPE=llm
DIFY_ENDPOINT_MODEL_NAME=gpt-5.2-codex
# If fallback model uses different credentials/channel and is unstable, set it same as primary first.
DIFY_FALLBACK_MODEL=gpt-5.2-codex

# Optional smoke
DIFY_SMOKE_QUERY="实验室发生化学品泄漏时，第一步怎么做？"
DIFY_SMOKE_USER=recovery-smoke
DIFY_SMOKE_TIMEOUT_SEC=240
DIFY_SMOKE_RETRIES=3
DIFY_SMOKE_RETRY_INTERVAL_SEC=3
DIFY_FORCE_ROTATE_KEY=0

# Optional go-live preflight
RELEASE_DIR=release_exports/v8.1
WEB_HEALTH_URL=http://127.0.0.1:8088/health
# Default hard gate for release acceptance
GO_LIVE_ENFORCE_PROD_POLICY=1

# Optional embedding channel auto-fix (recommended on fresh servers)
AUTO_FIX_EMBEDDING_CHANNEL=1
# Leave empty to use defaults:
# docker-api-1 docker-worker-1 docker-plugin_daemon-1
EMBEDDING_TARGET_CONTAINERS=

# Optional stability settings
STABILITY_ROUNDS=3
STABILITY_INTERVAL_SEC=30
STABILITY_LIMIT=20
STABILITY_DIFY_TIMEOUT=180
# Official Dify release chain should use streaming here; blocking is unstable in current server runtime.
STABILITY_DIFY_RESPONSE_MODE=streaming
STABILITY_EVAL_CONCURRENCY=1
STABILITY_RETRY_ON_TIMEOUT=1
STABILITY_FAILOVER_DAYS=1
STABILITY_FAIL_STREAK_THRESHOLD=2
STABILITY_SKIP_HEALTH_CHECK=0
STABILITY_SKIP_CANARY=0

# Optional release policy
RELEASE_POLICY_PROFILE=prod
RELEASE_POLICY_RUN_SECONDARY=1
RELEASE_POLICY_SECONDARY_PROFILE=prod
RELEASE_POLICY_ENFORCE_SECONDARY=1
RELEASE_POLICY_STRICT=1

# Optional explicit Dify API container name. Keep empty to auto-detect.
DIFY_API_CONTAINER=
